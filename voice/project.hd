#include "asr.h"
extern "C"{ void * __dso_handle = 0 ;}
#include "setup.h"
#include "HardwareSerial.h"
#include "asr_event.h"
#include "asr_event.h"

uint32_t snid;
static volatile bool query_pending;
static uint32_t query_started_ms;
void ASR_CODE();
void asrpro_uart_task();

