static void request_esp32(const char *request)
{
  query_pending = true;
  query_started_ms = millis();
  Serial.println(request);
}

static void speak_temperature(int32_t temperature_hundredths)
{
  enter_wakeup(10000);
  play_audio(10003);
  play_num((int64_t)temperature_hundredths, 1);
  play_audio(10004);
}

static void speak_heart_rate(uint32_t heart_rate_hundredths)
{
  enter_wakeup(10000);
  if (heart_rate_hundredths == 0U) {
    play_audio(10007);
    return;
  }
  play_audio(10005);
  play_num((int64_t)heart_rate_hundredths, 1);
  play_audio(10006);
}

static void speak_coordinate(int32_t latitude_e6, int32_t longitude_e6)
{
  enter_wakeup(10000);
  play_audio(10010);
  play_num((int64_t)latitude_e6 / 10000, 1);
  play_audio(10011);
  play_num((int64_t)longitude_e6 / 10000, 1);
}

static void handle_asrpro_frame(String frame)
{
  const String temperature_prefix = "ASR,DATA,TEMP,";
  const String heart_prefix = "ASR,DATA,HEART,";
  const String all_prefix = "ASR,DATA,ALL,";
  const String coordinate_prefix = "ASR,DATA,COORD,";

  frame.trim();
  if (frame.startsWith("ASR,DATA,")) {
    query_pending = false;
  }
  if (frame == "ASR,DATA,NONE") {
    enter_wakeup(10000);
    play_audio(10008);
  } else if (frame == "ASR,DATA,COORD,NONE") {
    enter_wakeup(10000);
    play_audio(10012);
  } else if (frame.startsWith(temperature_prefix)) {
    speak_temperature(frame.substring(temperature_prefix.length()).toInt());
  } else if (frame.startsWith(heart_prefix)) {
    speak_heart_rate((uint32_t)frame.substring(heart_prefix.length()).toInt());
  } else if (frame.startsWith(all_prefix)) {
    const int separator = frame.indexOf(',', all_prefix.length());

    if (separator >= 0) {
      speak_temperature(frame.substring(all_prefix.length(), separator).toInt());
      speak_heart_rate((uint32_t)frame.substring(separator + 1).toInt());
    }
  } else if (frame.startsWith(coordinate_prefix)) {
    const int separator = frame.indexOf(',', coordinate_prefix.length());

    if (separator >= 0) {
      speak_coordinate(frame.substring(coordinate_prefix.length(), separator).toInt(),
                       frame.substring(separator + 1).toInt());
    }
  }
}

void asrpro_uart_task()
{
  while (1) {
    if (Serial.available() > 0) {
      handle_asrpro_frame(Serial.readStringUntil('\n'));
    }
    if (query_pending && (uint32_t)(millis() - query_started_ms) > 1500U) {
      query_pending = false;
      enter_wakeup(10000);
      play_audio(10009);
    }
    delay(10);
  }
}

/*描述该功能...
*/
void ASR_CODE(){
  //本函数是语音识别成功钩子程序
  //运行时间越短越好，复杂控制启动新线程运行
  //唤醒时间设置必须在ASR_CODE中才有效
  set_state_enter_wakeup(10000);
  //用switch分支选择，根据不同的识别成功的ID执行相应动作，点击switch左上齿轮
  //可以增加分支项
  switch (snid) {
   case 1:
    digitalWrite(4,0);
    break;
   case 2:
    digitalWrite(4,1);
    break;
   case 5:
    request_esp32("ASR,GET,TEMP");
    break;
   case 6:
    request_esp32("ASR,GET,HEART");
    break;
   case 7:
    request_esp32("ASR,GET,ALL");
    break;
   case 8:
    request_esp32("ASR,GET,COORD");
    break;
  }
  //除了switch分支选择，也可用如果判断识别ID的值来执行动作
  if((snid) == 3){
    digitalWrite(4,0);
  }
  if((snid) == 4){
    digitalWrite(4,1);
  }
  //采用如果判断模块，可更方便复制

}

void hardware_init(){
  //需要操作系统启动后初始化的内容
  //音量范围1-7
  vol_set(5);
  setPinFun(13,SECOND_FUNCTION);
  setPinFun(14,SECOND_FUNCTION);
  Serial.begin(9600);
  xTaskCreate(asrpro_uart_task,"asrpro_uart",256,NULL,4,NULL);
  vTaskDelete(NULL);
}

void setup()
{
  //需要操作系统启动前初始化的内容
  //播报音下拉菜单可以选择，合成音量是指TTS生成文件的音量
  //欢迎词指开机提示音，可以为空
  //退出语音是指休眠时提示音，可以为空
  //休眠后用唤醒词唤醒后才能执行命令，唤醒词最多5个。回复语可以空。ID范围为0-9999
  //{ID:0,keyword:"唤醒词",ASR:"天问五幺",ASRTO:"我在"}
  //{ID:1,keyword:"命令词",ASR:"打开灯光",ASRTO:"好的，马上打开灯光"}
  //{ID:2,keyword:"命令词",ASR:"关闭灯光",ASRTO:"好的，马上关闭灯光"}
  //{ID:3,keyword:"命令词",ASR:"灯光打开",ASRTO:"好的，马上打开灯光"}
  //{ID:4,keyword:"命令词",ASR:"灯光关闭",ASRTO:"好的，马上关闭灯光"}
  //{ID:5,keyword:"命令词",ASR:"当前温度",ASRTO:""}
  //{ID:6,keyword:"命令词",ASR:"当前心率",ASRTO:""}
  //{ID:7,keyword:"命令词",ASR:"当前状态",ASRTO:""}
  //{ID:8,keyword:"命令词",ASR:"当前坐标",ASRTO:""}
  setPinFun(4,FIRST_FUNCTION);
  pinMode(4,output);
}








