static float wrap_phase_pct(float phase_pct) { 
    while (phase_pct >= 100.0f) phase_pct -= 100.0f; 
    while (phase_pct < 0.0f) phase_pct += 100.0f; 
    return phase_pct; 
}

static void get_curve_target(const JointCurvePoint_t *curve, uint32_t count, float phase, float *deg) {
    phase = wrap_phase_pct(phase);
    for (uint32_t i = 0; i < count - 1; i++) {
        if (phase <= curve[i+1].phase_pct) {
            float t = (phase - curve[i].phase_pct) / (curve[i+1].phase_pct - curve[i].phase_pct);
            *deg = curve[i].joint_deg + t * (curve[i+1].joint_deg - curve[i].joint_deg);
            return;
        }
    }
    *deg = curve[count-1].joint_deg;
}

static void Joint_Init(JointController_t *j, const char *name, uint16_t id, float dir, float ratio, const JointCurvePoint_t *c, uint32_t cnt) {
    memset(j, 0, sizeof(*j)); j->name = name; j->motor_id = id; j->dir_sign = dir; j->reduction_ratio = ratio; j->curve = c; j->point_count = cnt;
    j->phase_adv_state = PHASE_ADVANCE_PCT; j->slew_base_state = POS_SLEW_BASE_RAD_S_INIT; j->wff_alpha_state = WFF_LPF_ALPHA_INIT;
    j->last_servo_status = HAL_OK; j->cmd.id = id;
	j->is_calibrated = 0; // 确保开机时是未校准
}

static void Joint_PrepareRun(JointController_t *j, float phase_pct) {
    float target_deg; get_curve_target(j->curve, j->point_count, phase_pct + j->phase_adv_state, &target_deg);
    if (j->traj_scale < 1.0f) j->traj_scale += 0.015f; if (j->soft_kp < KP_TARGET) j->soft_kp += 0.003f;
    j->cmd.mode = 1U; j->cmd.K_P = j->soft_kp; j->cmd.K_W = KW_TARGET;
    j->target_ref_deg = target_deg * j->traj_scale;
    j->cmd.Pos = j->center_pos + j->dir_sign * (j->target_ref_deg * DEG_TO_RAD) * j->reduction_ratio;
}

static void Joint_HandleResponse(JointController_t *j, HAL_StatusTypeDef status) {
    j->last_servo_status = status; 
    
    if (status == HAL_OK && j->data.correct) { 
        j->fb_pos_state = j->data.Pos; 
        j->fb_valid_state = 1U; 

        // 只要是开机后第一次收到电机的合法回包，就立刻把这个点定为零点
        if (j->is_calibrated == 0) {
            j->center_pos = j->data.Pos; // 记录初始位置
            j->is_calibrated = 1;        // 以后再也不进这个判断了
        }
    }
}

static float Joint_GetFeedbackDeg(const JointController_t *j) {
    float fb = j->fb_valid_state ? j->fb_pos_state : j->data.Pos;
    float div = (j->dir_sign * j->reduction_ratio * DEG_TO_RAD);
    if (fabsf(div) < 1e-6f) return 0.0f;
    return (fb - j->center_pos) / div;
}

/* ==================================================================
 * MAIN 执行逻辑
 * ================================================================== */
int main(void) {
    JointController_t knee, hip;
    uint32_t last_tick, last_print;
    uint32_t gait_elapsed_prev_ms = 0;

    HAL_Init();
    SystemClock_Config(); 
    MX_GPIO_Init();
    MX_USART1_UART_Init();

    // --- [监控 1] 确认时钟和串口 OK ---
    HAL_Delay(100);
    const char* m1 = "\r\n[Step 1] CPU & UART1 OK. Initializing USART3/CAN...\r\n";
    HAL_UART_Transmit(&huart1, (uint8_t*)m1, strlen(m1), 100);

    MX_USART3_UART_Init();
    MX_CAN1_Init(); 

    // --- [监控 2] 准备启动 CAN ---
    const char* m2 = "[Step 2] Ready to Start CAN & Filters...\r\n";
    HAL_UART_Transmit(&huart1, (uint8_t*)m2, strlen(m2), 100);
    USER_CAN1_Start(); 

    // --- [监控 3] 准备停止电机指令 ---
    const char* m3 = "[Step 3] Sending motor_stop_init() [Blocking Search]...\r\n";
    HAL_UART_Transmit(&huart1, (uint8_t*)m3, strlen(m3), 100);
    HAL_Delay(50);
    motor_stop_init(); // 如果卡在这里，串口会停留在 Step 3

    // --- [监控 4] 准备使能电机 ---
    const char* m4 = "[Step 4] Sending motor_init(0, 1) [Waiting for ACK]...\r\n";
    HAL_UART_Transmit(&huart1, (uint8_t*)m4, strlen(m4), 100);
    HAL_Delay(50);
    motor_init(0, 1);  // 如果卡在这里，说明没收到节点 0 的应答回包
	HAL_Delay(50);
    motor_init(1, 1);  // 初始化 ID 1 (新增)
    // --- [监控 5] 准备校准 ---
    const char* m5 = "[Step 5] Motor Init Finished. Now Calibrating...\r\n";
    HAL_UART_Transmit(&huart1, (uint8_t*)m5, strlen(m5), 100);
    HAL_Delay(200);
    Calibrate_motor_init(); 

    // --- [监控 6] 全部初始化完成 ---
    const char* m6 = "[Step 6] ALL SUCCESS! Entering Main Loop.\r\n";
    HAL_UART_Transmit(&huart1, (uint8_t*)m6, strlen(m6), 100);

    // 统一初始化结构体
    Joint_Init(&knee, "knee", KNEE_MOTOR_ID, KNEE_DIR_SIGN, KNEE_REDUCTION_RATIO, kKneeCurve, KNEE_POINT_COUNT);
    Joint_Init(&hip, "hip", HIP_MOTOR_ID, HIP_DIR_SIGN, HIP_REDUCTION_RATIO, kHipCurve, HIP_POINT_COUNT);

    last_tick = HAL_GetTick(); last_print = 0;
     HAL_UART_Transmit(&huart1, (uint8_t*)"System Fusion Booted!\r\n", 23, 100);

    

   
    while (1) {
        uint32_t now = HAL_GetTick();
        if (now - last_tick >= CONTROL_PERIOD_MS) {
            last_tick = now;

            if (now < (INIT_HOLD_MS + 500)) { // 稍微延长初始化锁定
                knee.cmd.mode = 0; Joint_HandleResponse(&knee, SERVO_Send_recv(&knee.cmd, &knee.data));
                hip.cmd.mode = 0;  Joint_HandleResponse(&hip, SERVO_Send_recv(&hip.cmd, &hip.data));
                set_input_pos(0, motor[0].init_pos, 0, 0);
            } 
            else {
                uint32_t gait_ms = (now - INIT_HOLD_MS) % GAIT_PERIOD_MS;
                float phase = (float)gait_ms * 100.0f / (float)GAIT_PERIOD_MS;
                
                // 修复警告：使用此变量
                if (gait_ms < gait_elapsed_prev_ms) {
                    // 一个步态周期结束
                }
                gait_elapsed_prev_ms = gait_ms;

                Joint_PrepareRun(&knee, phase); Joint_HandleResponse(&knee, SERVO_Send_recv(&knee.cmd, &knee.data));
                Joint_PrepareRun(&hip, phase);  Joint_HandleResponse(&hip, SERVO_Send_recv(&hip.cmd, &hip.data));

                float ankle_deg = ankle_wave_deg_from_percent(phase);
                float ankle_turn = motor[0].init_pos + ANKLE_CMD_DIR * (ankle_deg * ANKLE_TURN_PER_DEG);
               // 重点：同时尝试发送给两个 ID
                set_input_pos(0, ankle_turn, 0, 0); 
                set_input_pos(1, ankle_turn, 0, 0); 
            }

            if (now - last_print >= PRINT_PERIOD_MS) {
                last_print = now;

                // 1. 修正时间戳显示，防止出现几亿的下溢数字
                float plot_time = (now < INIT_HOLD_MS) ? 0.0f : (float)(now - INIT_HOLD_MS);

                // 2. 计算当前步态的目标角度 (仅在初始化结束后开始显示波形)
                float a_ref = 0.0f;
                if (now >= INIT_HOLD_MS) {
                    uint32_t g_ms = (now - INIT_HOLD_MS) % GAIT_PERIOD_MS;
                    a_ref = ankle_wave_deg_from_percent((float)g_ms * 100.0f / (float)GAIT_PERIOD_MS);
                }

                // 3. 同时读取 ID 0 和 ID 1 的反馈（解决 CAN 电机不转/无反馈的排查）
                float a_fb0 = (motor[0].pos - motor[0].init_pos) / (ANKLE_CMD_DIR * ANKLE_TURN_PER_DEG);
                float a_fb1 = (motor[1].pos - motor[1].init_pos) / (ANKLE_CMD_DIR * ANKLE_TURN_PER_DEG);
                
                // 只要 ID 0 或 ID 1 其中一个有数值反馈，就显示它
                float final_fb = (fabsf(a_fb0) > 0.001f) ? a_fb0 : a_fb1;

                // 4. 发送给 VOFA
                Vofa_SendFrame(plot_time, 0.0f, &knee, &hip, a_ref, final_fb);
            }
        }
    }
}

static void Vofa_SendFrame(float t_ms, float phase_pct, const JointController_t *knee, const JointController_t *hip, float ankle_ref, float ankle_fb) {
    char tx[400];
    int len = sprintf(tx, "demo:%.1f,%d,%d,%.2f,%.2f,%.2f,%.2f,%.2f,%.2f\n",
                      t_ms, (int)knee->last_servo_status, (int)hip->last_servo_status,
                      knee->target_ref_deg, Joint_GetFeedbackDeg(knee),
                      hip->target_ref_deg, Joint_GetFeedbackDeg(hip),
                      ankle_ref, ankle_fb);
    if (len > 0) HAL_UART_Transmit(&huart1, (uint8_t*)tx, (uint16_t)len, 20);
}

