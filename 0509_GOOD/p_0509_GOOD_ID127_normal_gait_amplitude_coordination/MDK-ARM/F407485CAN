/* --- 踝关节步态插值 --- */
static float ankle_wave_deg_from_percent(float gait_percent) {
    static const float gait_key[] = {0.0f, 6.0f, 10.0f, 16.0f, 22.0f, 28.0f, 35.0f, 45.0f, 52.0f, 56.0f, 62.0f, 68.0f, 75.0f, 82.0f, 90.0f, 96.0f, 100.0f};
    static const float ankle_key[] = {-2.0f, -15.0f, -13.0f, -9.0f, -4.0f, 0.0f, 3.0f, 6.0f, 2.0f, -5.0f, -12.5f, -11.0f, -8.0f, -5.0f, -2.0f, -1.0f, -3.0f};
    const uint32_t point_num = (uint32_t)(sizeof(gait_key) / sizeof(gait_key[0]));
    if (gait_percent <= gait_key[0]) return ankle_key[0];
    if (gait_percent >= gait_key[point_num - 1]) return ankle_key[point_num - 1];
    for (uint32_t i = 0; i < point_num - 1; i++) {
        if (gait_percent <= gait_key[i + 1]) {
            float span = gait_key[i + 1] - gait_key[i];
            float ratio = (span > 0.0f) ? ((gait_percent - gait_key[i]) / span) : 0.0f;
            return ankle_key[i] + ratio * (ankle_key[i + 1] - ankle_key[i]);
        }
    }
    return ankle_key[point_num - 1];
}

